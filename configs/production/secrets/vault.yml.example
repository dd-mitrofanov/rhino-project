---
# =============================================================================
# Production secrets — copy to vault.yml and encrypt (ansible-vault encrypt …)
# =============================================================================
#   cp configs/production/secrets/vault.yml.example configs/production/secrets/vault.yml
# Single file: Xray, subscription API, Telegram bot, Grafana (monitoring).

# --- Server IPs ---
vault_ru_msk_1_ip: "IP"
vault_ru_msk_2_ip: "IP"

vault_nl_ams_1_ip: "IP"
vault_de_fra_1_ip: "IP"

# --- Reality key pairs (generated by: make gen-keys) ---
vault_ru_msk_1_reality_private_key: "PRIVATE_KEY"
vault_ru_msk_1_reality_public_key: "PUBLIC_KEY"
vault_ru_msk_2_reality_private_key: "PRIVATE_KEY"
vault_ru_msk_2_reality_public_key: "PUBLIC_KEY"

vault_nl_ams_1_reality_private_key: "PRIVATE_KEY"
vault_nl_ams_1_reality_public_key: "PUBLIC_KEY"
vault_de_fra_1_reality_private_key: "PRIVATE_KEY"
vault_de_fra_1_reality_public_key: "PUBLIC_KEY"

# --- VLESS UUIDs (generated by: make gen-keys) ---
vault_client_uuid: "UUID"

vault_nl_ams_1_uuid: "UUID"
vault_de_fra_1_uuid: "UUID"

# Shared secret: Telegram bot subscription HTTP and RU external API proxies
vault_subscription_api_token: "REPLACE_WITH_LONG_RANDOM_HEX_OR_UUID"

# --- Telegram bot (nl-ams-1) ---
telegram_bot_token: "1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ"
telegram_bot_admin_id: 123456789
telegram_bot_postgres_password: "replace-with-strong-password"

# --- External subscription API (each RU relay) ---
subscription_api_domain: "your-subscription-domain.example.com"
subscription_api_port: 8443
subscription_api_internal_hostname: "rhino-nl-ams-1.your-domain.com"
subscription_api_internal_port: 9443
subscription_api_acme_email: "your-email@example.com"
# Optional; default is production LE (see role defaults).
# subscription_api_acme_directory: "https://acme-v02.api.letsencrypt.org/directory"

# --- Grafana (monitoring stack on de-fra-1) ---
vault_grafana_admin_user: admin
vault_grafana_domain: grafana.example.com
vault_grafana_admin_password: "STRONG_PASSWORD"
