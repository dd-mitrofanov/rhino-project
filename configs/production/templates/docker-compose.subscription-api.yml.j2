---
services:
  subscription-api:
    build:
      context: ./subscription-api
      dockerfile: Dockerfile
    container_name: subscription-api
    restart: unless-stopped
    env_file:
      - .env
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"

  caddy:
    image: caddy:2-alpine
    container_name: subscription-caddy
    restart: unless-stopped
    ports:
      - "80:80"
      - "{{ subscription_api_port }}:{{ subscription_api_port }}"
    volumes:
      - ./Caddyfile:/etc/caddy/Caddyfile:ro
      - ./certs:/etc/caddy/certs:ro
      - ./certbot/www:/var/www/certbot:ro
      - caddy_data:/data
      - caddy_config:/config
    depends_on:
      - subscription-api
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"

volumes:
  caddy_data:
  caddy_config:
