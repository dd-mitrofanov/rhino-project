---
services:
  bot:
    build:
      context: ./bot
      dockerfile: Dockerfile
    container_name: telegram-bot
    restart: unless-stopped
    ports:
      - "{{ subscription_api_internal_port }}:8000"
    env_file:
      - .env
    depends_on:
      db:
        condition: service_healthy
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"

  db:
    image: postgres:{{ telegram_bot_postgres_version }}
    container_name: telegram-bot-db
    restart: unless-stopped
    env_file:
      - .env
    volumes:
      - "{{ telegram_bot_dir }}/pgdata:/var/lib/postgresql/data"
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{ telegram_bot_postgres_user }} -d {{ telegram_bot_postgres_db }}"]
      interval: 5s
      timeout: 5s
      retries: 5
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"

  user-mapping-exporter:
    build:
      context: ./mapping-exporter
      dockerfile: Dockerfile
    container_name: user-mapping-exporter
    restart: unless-stopped
    env_file:
      - .env
    ports:
      - "{{ user_mapping_exporter_port }}:{{ user_mapping_exporter_port }}"
    depends_on:
      db:
        condition: service_healthy
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
