---
# Пример секретов для deploy-test-server (скопировать в vault.yml и зашифровать).
#
#   cp configs/test/secrets/vault.yml.example configs/test/secrets/vault.yml
#   # заполнить значения или сгенерировать: make gen-keys-test
#   ansible-vault encrypt configs/test/secrets/vault.yml
#
# Запуск: export ANSIBLE_VAULT_PASSWORD_FILE=...  или  ansible-playbook --ask-vault-pass
#
# Ключи Reality: сгенерировать make gen-keys-test или как в проде (make gen-keys).
# На сервер идёт только privateKey; publicKey нужен клиенту для подключения.

vault_vless_uuid: "00000000-0000-0000-0000-000000000000"

# Reality key pair (сервер использует private, клиент — public)
vault_reality_private_key: "YOUR_REALITY_PRIVATE_KEY_BASE64"
vault_reality_public_key: "YOUR_REALITY_PUBLIC_KEY_BASE64"
